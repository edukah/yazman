[
  {"text": "====================  Yazman Editor Manual  ====================", "style": "font-size: 1.7em; color: #6c5ce7; font-weight: bold;"},
  {"text": "", "style": ""},
  {"text": "How to initialize:", "style": "font-size: 1.7em; color: #00b894; font-weight: bold;"},
  {"text": "const editor = new Yazman(document.getElementById('editor'), {", "style": ""},
  {"text": "  placeholder: 'Start typing...',", "style": ""},
  {"text": "  toolbar: [", "style": ""},
  {"text": "    ['bold', 'italic'],", "style": ""},
  {"text": "    ['headerTwo', 'headerThree'],", "style": ""},
  {"text": "    ['preformatted', 'blockquote'],", "style": ""},
  {"text": "    ['subscript', 'supscript'],", "style": ""},
  {"text": "    ['hyperlink'],", "style": ""},
  {"text": "    ['figureImage'],", "style": ""},
  {"text": "    [{ listItem: 'ordered' }, { listItem: 'unordered' }]", "style": ""},
  {"text": "  ],", "style": ""},
  {"text": "  history: { counterTiming: 2000, saveCoefficient: 6 },", "style": ""},
  {"text": "  autosave: {", "style": ""},
  {"text": "    enable: true,", "style": ""},
  {"text": "    counterTiming: 5000,", "style": ""},
  {"text": "    preventUnload: true,", "style": ""},
  {"text": "    adaptor: function () { /* save logic */ }", "style": ""},
  {"text": "  },", "style": ""},
  {"text": "  ImageUploader: CustomUploaderClass,", "style": ""},
  {"text": "  onError: (error, context) => { /* handle error */ }", "style": ""},
  {"text": "});", "style": ""},
  {"text": "", "style": ""},
  {"text": "API Methods:", "style": "font-size: 1.7em; color: #00b894; font-weight: bold;"},
  {"text": "editor.format(start, end, formatObj)     Apply formatting to range", "style": ""},
  {"text": "editor.insertNode(nodeData, index)        Insert content at position", "style": ""},
  {"text": "editor.deleteContent(start, end)          Delete content in range", "style": ""},
  {"text": "editor.update()                           Regenerate paper model and UI", "style": ""},
  {"text": "editor.isEmpty()                          Check if editor has content", "style": ""},
  {"text": "editor.focus()                            Focus the editor", "style": ""},
  {"text": "editor.hasFocus()                         Check if editor is focused", "style": ""},
  {"text": "editor.isSaved                            Whether content is saved", "style": ""},
  {"text": "editor.status('message', duration)         Show status message", "style": ""},
  {"text": "", "style": ""},
  {"text": "Available Config Keys:", "style": "font-size: 1.7em; color: #00cec9; font-weight: bold;"},
  {"text": "placeholder          string           Placeholder text when empty", "style": ""},
  {"text": "toolbar              array            Button groups for toolbar", "style": ""},
  {"text": "history              object           Undo/redo configuration", "style": ""},
  {"text": "autosave             object           Auto-save configuration", "style": ""},
  {"text": "ImageUploader        class            Custom image upload handler", "style": ""},
  {"text": "onError              function         Error callback: (error, context) => {}", "style": ""},
  {"text": "", "style": ""},
  {"text": "History Options:", "style": "color: #e17055; font-weight: bold;"},
  {"text": "counterTiming        number           Debounce delay in ms (default: 2000)", "style": ""},
  {"text": "saveCoefficient      number           Save frequency multiplier (default: 6)", "style": ""},
  {"text": "", "style": ""},
  {"text": "Autosave Options:", "style": "color: #e17055; font-weight: bold;"},
  {"text": "enable               boolean          Enable auto-save", "style": ""},
  {"text": "counterTiming        number           Save interval in ms (default: 5000)", "style": ""},
  {"text": "saveCoefficient      number           Save frequency multiplier", "style": ""},
  {"text": "preventUnload        boolean          Warn before page unload if unsaved", "style": ""},
  {"text": "adaptor              function         Callback to handle save logic", "style": ""},
  {"text": "", "style": ""},
  {"text": "Toolbar Formats:", "style": "font-size: 1.7em; color: #00b894; font-weight: bold;"},
  {"text": "bold                 <strong>         Bold text", "style": ""},
  {"text": "italic               <em>             Italic text", "style": ""},
  {"text": "headerTwo            <h2>             Heading level 2", "style": ""},
  {"text": "headerThree          <h3>             Heading level 3", "style": ""},
  {"text": "preformatted         <pre>            Preformatted code block", "style": ""},
  {"text": "blockquote           <blockquote>     Block quote", "style": ""},
  {"text": "subscript            <sub>            Subscript text", "style": ""},
  {"text": "supscript            <sup>            Superscript text", "style": ""},
  {"text": "hyperlink            <a>              Hyperlink (opens dialog)", "style": ""},
  {"text": "figureImage          <figure>         Image with caption", "style": ""},
  {"text": "{ listItem: 'ordered' }                Ordered list", "style": ""},
  {"text": "{ listItem: 'unordered' }              Unordered list", "style": ""},
  {"text": "", "style": ""},
  {"text": "Dark Mode:", "style": "color: #636e72; font-weight: bold;"},
  {"text": "Add .dark-mode class to <body> to activate dark theme.", "style": ""},
  {"text": "", "style": ""},
  {"text": "============================================================", "style": "color: #6c5ce7;"}
]
